{
  "name": "permission-wallet-dapp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "test": "DATABASE_URL='postgresql://postgres@localhost:5432/wallet?schema=stt_test' prisma db push && DATABASE_URL='postgresql://postgres@localhost:5432/wallet?schema=stt_test' node --import tsx --test --test-concurrency=1 'src/**/*.test.ts'",
    "test:unit": "node --import tsx --test --test-concurrency=1 'src/lib/contracts/*.test.ts' 'src/components/user/workspace/atoms/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "sync:blueprint": "node ./scripts/sync-blueprint.mjs",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  },
  "dependencies": {
    "@harmoniclabs/crypto": "^0.3.0",
    "@meshsdk/common": "1.9.0",
    "@meshsdk/core": "1.9.0",
    "@meshsdk/core-cst": "1.9.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "7.8.0",
    "@walletconnect/sign-client": "^2.23.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ethereum-cryptography": "^3.2.0",
    "jotai": "^2.20.0",
    "lucide-react": "1.17.0",
    "motion": "^12.40.0",
    "next": "16.2.9",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "3.6.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "25.9.2",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@walletconnect/types": "^2.23.9",
    "eslint": "9.39.3",
    "eslint-config-next": "16.2.7",
    "eslint-plugin-unused-imports": "^4.4.1",
    "postcss": "^8.5.15",
    "prisma": "^7.8.0",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
