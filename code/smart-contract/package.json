{
  "name": "permission-based-wallet",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "preflight": "node scripts/check-toolchain.mjs",
    "check": "aiken check -D",
    "check:summary": "node scripts/check-summary.mjs",
    "fmt": "aiken fmt",
    "docs": "aiken docs",
    "watch": "aiken check --watch",
    "fuzz": "aiken check --max-success 10000",
    "sync": "node scripts/check-toolchain.mjs && aiken build && pnpm -C ../dApp sync:blueprint",
    "verify": "node scripts/check-toolchain.mjs && aiken fmt --check && aiken check -D && for f in offchain/*.mjs; do node --check \"$f\" || exit 1; done",
    "mint": "node offchain/mint_state_token.mjs",
    "forward": "node offchain/forward_stt_token.mjs"
  },
  "dependencies": {
    "@meshsdk/core": "^1.9.0",
    "@meshsdk/core-cst": "^1.9.0",
    "cbor": "^10.0.12",
    "dotenv": "^17.4.2",
    "ethereum-cryptography": "^3.2.0"
  }
}
